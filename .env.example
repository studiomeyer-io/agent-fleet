# Required: Claude Code CLI must be installed and authenticated
# Install: npm install -g @anthropic-ai/claude-code

# Optional: Tavily API key for deep web research
# Get yours at https://tavily.com
TAVILY_API_KEY=

# Optional: PostgreSQL for report persistence
# Reports are always saved to files regardless of this setting
DATABASE_URL=postgresql://user:password@localhost:5432/agent_fleet

# Optional (v0.2+): LangGraph stateful workflow mode
# Same DATABASE_URL is reused for the langgraph.* checkpoint tables.
# Set the schema name if you want it different from the default:
# LANGGRAPH_SCHEMA=langgraph

# Opt-in for API billing instead of subscription mode (CI / server use)
# Default: subscription-flat via your Claude Pro/Max plan
# AGENT_FLEET_USE_API_KEY=1
